{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "LARSA InfluxDB datasource",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""},
    {"type": "panel", "id": "heatmap", "name": "Heatmap", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "LARSA Regime Monitor — BH mass, mean reversion, regime classification",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "external link",
      "tags": ["larsa"],
      "title": "Live Trading",
      "tooltip": "Go to main trading dashboard",
      "type": "dashboards",
      "url": ""
    }
  ],
  "panels": [

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 200,
      "title": "BH Mass — All Symbols",
      "type": "row"
    },

    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1.5},
              {"color": "red", "value": 2.0}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 1},
      "id": 201,
      "options": {
        "legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "title": "BH Mass Daily — All Symbols",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "from(bucket: \"larsa_metrics\")\n  |> range(start: $__timeFrom, stop: $__timeTo)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"larsa_symbol\" and r[\"_field\"] == \"bh_mass_daily\")\n  |> aggregateWindow(every: $__interval, fn: mean, createEmpty: false)\n  |> yield(name: \"bh_mass_daily\")",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 10},
      "id": 202,
      "options": {
        "legend": {"calcs": ["last"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "title": "BH Mass Hourly — All Symbols",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "from(bucket: \"larsa_metrics\")\n  |> range(start: $__timeFrom, stop: $__timeTo)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"larsa_symbol\" and r[\"_field\"] == \"bh_mass_hourly\")\n  |> aggregateWindow(every: $__interval, fn: mean, createEmpty: false)\n  |> yield(name: \"bh_mass_hourly\")",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 10},
      "id": 203,
      "options": {
        "legend": {"calcs": ["last"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "title": "BH Mass 15m — All Symbols",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "from(bucket: \"larsa_metrics\")\n  |> range(start: $__timeFrom, stop: $__timeTo)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"larsa_symbol\" and r[\"_field\"] == \"bh_mass_15m\")\n  |> aggregateWindow(every: $__interval, fn: mean, createEmpty: false)\n  |> yield(name: \"bh_mass_15m\")",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 19},
      "id": 210,
      "title": "Mean Reversion (OU z-score)",
      "type": "row"
    },

    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": true,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "super-light-yellow", "value": -1},
              {"color": "super-light-red", "value": 2}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 20},
      "id": 211,
      "options": {
        "legend": {"calcs": ["last", "mean"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "abs-desc"}
      },
      "title": "Mean Reversion Z-Score (OU) — All Symbols",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "from(bucket: \"larsa_metrics\")\n  |> range(start: $__timeFrom, stop: $__timeTo)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"larsa_symbol\" and r[\"_field\"] == \"ou_zscore\")\n  |> aggregateWindow(every: $__interval, fn: mean, createEmpty: false)\n  |> yield(name: \"ou_zscore\")",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 29},
      "id": 220,
      "title": "Regime Classification",
      "type": "row"
    },

    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null},
              {"color": "green", "value": 0},
              {"color": "orange", "value": 4},
              {"color": "red", "value": 6}
            ]
          },
          "unit": "short",
          "displayName": "${__field.labels.symbol}",
          "min": 0,
          "max": 7
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 30},
      "id": 221,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "title": "Current TF Score per Symbol (0=flat, 4-7=trending)",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "from(bucket: \"larsa_metrics\")\n  |> range(start: -30m)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"larsa_symbol\" and r[\"_field\"] == \"tf_score\")\n  |> last()\n  |> yield(name: \"tf_score\")",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null},
              {"color": "green", "value": 0.5},
              {"color": "red", "value": 1.2}
            ]
          },
          "unit": "short",
          "displayName": "${__field.labels.symbol}",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 36},
      "id": 222,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "title": "Current BH Mass Daily per Symbol",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "from(bucket: \"larsa_metrics\")\n  |> range(start: -30m)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"larsa_symbol\" and r[\"_field\"] == \"bh_mass_daily\")\n  |> last()\n  |> yield(name: \"bh_mass\")",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 42},
      "id": 230,
      "title": "OU Half-Life Estimates",
      "type": "row"
    },

    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "short",
          "displayName": "${__field.labels.symbol}",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 43},
      "id": 231,
      "options": {
        "legend": {"calcs": ["last"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "title": "OU Half-Life (bars)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "from(bucket: \"larsa_metrics\")\n  |> range(start: $__timeFrom, stop: $__timeTo)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"larsa_symbol\" and r[\"_field\"] == \"ou_halflife\")\n  |> aggregateWindow(every: $__interval, fn: mean, createEmpty: false)\n  |> yield(name: \"ou_halflife\")",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "percentunit",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 43},
      "id": 232,
      "options": {
        "legend": {"calcs": ["last"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "title": "GARCH Volatility Forecast",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "from(bucket: \"larsa_metrics\")\n  |> range(start: $__timeFrom, stop: $__timeTo)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"larsa_symbol\" and r[\"_field\"] == \"garch_vol\")\n  |> aggregateWindow(every: $__interval, fn: mean, createEmpty: false)\n  |> yield(name: \"garch_vol\")",
          "refId": "A"
        }
      ]
    }

  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["larsa", "regime"],
  "templating": {"list": []},
  "time": {"from": "now-12h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "LARSA Regime Monitor",
  "uid": "larsa-regime-monitor",
  "version": 1
}
